let x : int = 1;
switch (x) {
    case 1:
        let a : int = 10;
    case 2:
        let b : int = 20;
    default:
        let c : int = 30;
}
let c : char = 'a';
switch (c) {
    case 'a':
        let a : int = 10;
    default:
        let b : int = 20;
}
let s : string = "opt";
switch (s) {
    case "opt":
        let a : int = 10;
}
